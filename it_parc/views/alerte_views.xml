<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_it_alerte_tree" model="ir.ui.view">
        <field name="name">it.alerte.tree</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <list string="Alertes" decoration-danger="days_remaining &lt;= 7">
                <field name="name"/>
                <field name="alert_type"/>
                <field name="equipment_id"/>
                <field name="contract_id"/>
                <field name="expiry_date"/>
                <field name="days_remaining"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_it_alerte_form" model="ir.ui.view">
        <field name="name">it.alerte.form</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <form string="Alerte">
                <header>
                    <button name="action_dismiss" type="object" string="Marquer traitée"
                            invisible="state != 'active'" class="oe_highlight"
                            groups="it_parc.group_it_manager"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="alert_type"/>
                        <field name="equipment_id"/>
                        <field name="contract_id"/>
                        <field name="expiry_date"/>
                        <field name="days_remaining"/>
                        <field name="message"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_it_alerte" model="ir.actions.act_window">
        <field name="name">Alertes IT</field>
        <field name="res_model">it.alerte</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'active')]</field>
        <field name="groups_id" eval="[(6, 0, [ref('group_it_technician'), ref('group_it_manager')])]"/>
    </record>
</odoo>
