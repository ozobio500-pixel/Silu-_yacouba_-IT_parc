<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="group_it_technician" model="res.groups">
        <field name="name">IT Technicien</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>
    <record id="group_it_manager" model="res.groups">
        <field name="name">IT Manager</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('group_it_technician'))]"/>
    </record>

    <!-- Record rules -->
    <record id="rule_it_parc_equipment_technician" model="ir.rule">
        <field name="name">IT Parc équipements - Technicien lecture</field>
        <field name="model_id" ref="model_it_parc_equipment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_it_technician'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="rule_it_parc_equipment_manager" model="ir.rule">
        <field name="name">IT Parc équipements - Manager complet</field>
        <field name="model_id" ref="model_it_parc_equipment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
    </record>
    <record id="rule_it_parc_intervention_technician" model="ir.rule">
        <field name="name">IT Parc interventions - Technicien</field>
        <field name="model_id" ref="model_it_parc_intervention"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_it_technician'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="rule_it_parc_intervention_manager" model="ir.rule">
        <field name="name">IT Parc interventions - Manager complet</field>
        <field name="model_id" ref="model_it_parc_intervention"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
    </record>
    <record id="rule_it_alerte_technician" model="ir.rule">
        <field name="name">IT Alertes - Technicien lecture</field>
        <field name="model_id" ref="model_it_alerte"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_it_technician'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="rule_it_alerte_manager" model="ir.rule">
        <field name="name">IT Alertes - Manager complet</field>
        <field name="model_id" ref="model_it_alerte"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
    </record>


</odoo>
